    {
      "datasource": {
        "type": "prometheus",
        "uid": "PB624A9C3C3BF143F"
      },
      "description": "All SLOs with their objective and error budget remaining at multiple windows.\n\n**Remaining (5m/1h/6h/30d)** shows what fraction of the error budget would be left if the current error rate at that window persisted over the full 30-day period. 100% = no errors, 0% = exactly at budget, negative = over budget. Compare windows to distinguish spikes (low 5m, normal 6h) from sustained issues (low everywhere).\n\n**N/A** means insufficient history. Values are clamped to −100%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Objective"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/Remaining \\(.*\\)/"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.width",
                "value": 130
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "semi-dark-purple",
                      "value": 0
                    },
                    {
                      "color": "red",
                      "value": -1
                    },
                    {
                      "color": "orange",
                      "value": 0
                    },
                    {
                      "color": "yellow",
                      "value": 0.5
                    },
                    {
                      "color": "green",
                      "value": 0.9
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "noValue",
                "value": "N/A"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 201,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Remaining (30d)"
          }
        ]
      },
      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PB624A9C3C3BF143F"
          },
          "expr": "slo:objective:ratio{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PB624A9C3C3BF143F"
          },
          "expr": "clamp(\n  max without (sloth_window) (\n    slo:period_error_budget_remaining:ratio{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"}\n  ),\n  -1,\n  1\n)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PB624A9C3C3BF143F"
          },
          "expr": "clamp(\n  1 - max without (sloth_window) (\n    slo:current_burn_rate:ratio{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"}\n  ),\n  -1,\n  1\n)",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PB624A9C3C3BF143F"
          },
          "expr": "clamp(\n  1 -\n  slo:sli_error:ratio_rate1h{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"}\n  / on(sloth_id, sloth_slo, sloth_service) group_left\n  slo:error_budget:ratio{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"},\n  -1,\n  1\n)",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PB624A9C3C3BF143F"
          },
          "expr": "clamp(\n  1 -\n  slo:sli_error:ratio_rate6h{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"}\n  / on(sloth_id, sloth_slo, sloth_service) group_left\n  slo:error_budget:ratio{namespace=\"$namespace\", domain=\"domain\", sloth_service=~\"$service\", sloth_slo=~\"$slo\"},\n  -1,\n  1\n)",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "title": "SLO Status",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
